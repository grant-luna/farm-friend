extends layout

block append headStylesheets
  link(rel='stylesheet' href='/stylesheets/searches.css')
block append headJavascripts
  script(src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.0/papaparse.min.js")
  script(src='/javascripts/searches.js' type='module')
block main-content
  h3 Start a Search
  form.file-upload
    fieldset
      label(for='fileName') Name Your Search (for your records)
      input(type='text' required)
    fieldset
      label(for='file') Upload Your Fidelity Total Farm File
      input(type='file' accept='.csv' required)
    button.submit Upload File
  h3 Past Searches
  ul.user-searches-container
    each search in userSearches
      li.user-search-container= search.file_name
  
  button.sign-out Sign Out
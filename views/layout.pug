doctype html
html(lang='en')
  head
    meta(charset='utf-8')
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title Farm Friend
    block headStylesheets
      link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous")
      link(rel='stylesheet' href='/stylesheets/layout.css')
    block headJavascripts
      script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous")
      script(src='/javascripts/layout.js' type='module')
  body
    block header-content
      if session.signedIn
        header
          div.left-header-icons
            img.nav-menu-icon(src='/images/icons/nav-icon.png')
            a(href='/')
              img.farm-friend-icon(src='/images/icons/farm-friend-white-text-icon.png')
          div.account-dropdown-icon
            img.account-menu-headshot(src='/images/headshots/grant-luna.png')
            img.dropdown-icon(src='/images/icons/dropdown-icon.png')
      nav
        ul.nav-menu
          li
            a(href='/searches') Faster FastPeopleSearch
          li
            a(href='/mapme') MapMe
        div.title-rep-menu
          img(src='/images/headshots/grant-luna.png')
          h4= "Grant Luna"
          p Title Representative | Fidelity National Title
    main
      block main-content
        if session.signedIn
          include components/account-dropdown-menu.pug
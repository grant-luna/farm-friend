extends layout

block append headStylesheets
  link(rel='stylesheet' href='/stylesheets/sign-up.css')
block append headJavascripts
  script(src='/javascripts/sign-up.js')
block header-content
  img(src='/images/icons/farm-friend-icon.png')
block main-content
  if errorMessages
    ul
    each errorMessage in errorMessages
      li= errorMessage
    
  h3 Sign Up
  form(method='POST' action='/sign-up')
    fieldset
      label(for='firstName') First Name
      input(type='text' name='firstName' value=firstName required)
    fieldset
      label(for='lastName') Last Name
      input(type='text' name='lastName' value=lastName required)
    fieldset
      label(for='email') Email Address
      input(type='email' name='email' value=email required)
    fieldset
      label(for='password') Password
      input(type='password' name='password' value=password required)
    button.submit Sign-Up
  p Already have an account? 
    a(href='sign-in') Sign In

extends layout

block append headStylesheets
  link(rel='stylesheet' href='/stylesheets/sign-in.css')
block append headJavascripts
  script(src='/javascripts/sign-in.js')
block header-content
  img(src='/images/icons/farm-friend-icon.png')
block main-content
  if errorMessages
    ul
    each errorMessage in errorMessages
      li= errorMessage
  h3 Sign In
  form(method='POST' action='/sign-in')
    fieldset.form-floating.mb-3
      input.form-control(type='email' name='email' placeholder='Email Address' required)
      label(for='email') Email Address
    fieldset.form-floating.mb-3
      input.form-control(type='password' name='password' placeholder='Password' required)
      label(for='password') Password
    button.submit.btn.btn-primary Sign In
  p Don't have an account? 
    a(href='/sign-up') Sign Up

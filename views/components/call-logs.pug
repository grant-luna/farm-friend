// parent element is div.call-logs-menu
div.hide-call-log-menu-icon
  img.dropdown-icon(src='/images/icons/dropdown-black-icon.png')
h2 Call Logs
div.call-logs-menu-header
  div.call-logs-menu-header-element.log-a-call-button
    img(src='/images/icons/black-add-icon.png')
    h3 Log a Call
form.log-call-form
  img(src='/images/icons/close-button-icon.png')
  h3 Log a New Call
  fieldset.form-floating
    input.form-control(type='text' placeholder='Contact Person' name='contact-person')
    label(for='contact-peson') Who did you speak to?
  fieldset.form-floating
    textarea.form-control(rows='5' placeholder='Call Notes' name='call-notes')
    label(for='call-notes') Call Notes
  fieldset.form-floating
    input.form-control(type='number' placeholder='Would you like to save a phone number?' name='confirmed-number')
    label(for='confirmed-number') Would you like to save a phone number?
  button.btn.btn-primary(type='submit') Log Call
ul.call-logs-body
  each callLog in callLogs
    li.call-log-data
      div.call-log-data-item.mb-3
        h3 Call Date
        p #{callLog.date}
      div.call-log-data-item.mb-3
        h3 Contact Person
        p #{callLog.contactPerson}
      div.call-log-data-item.mb-3
        h3 Call Notes
        p #{callLog.callNotes}
